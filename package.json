{
  "name": "figma-portfolio-site",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node backend/server.js\" --names \"FRONT,BACK\" --prefix-colors \"cyan,magenta\"",
    "dev:front": "vite",
    "dev:back": "node backend/server.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mantine/core": "^8.0.0",
    "@mantine/dates": "^8.0.0",
    "@mantine/form": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "@mantine/notifications": "^8.0.0",
    "@tabler/icons-react": "^3.44.0",
    "i18next": "^23.7.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^13.5.0",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@rollup/wasm-node": "^4.61.1",
    "@types/matter-js": "^0.20.2",
    "@types/node": "^20.10.6",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^10.0.3",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "playwright": "^1.61.0",
    "typescript": "^5.4.3",
    "vite": "^5.1.0"
  }
}
